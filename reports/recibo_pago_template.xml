<!-- FILEPATH: /Users/christianvillarhode/Desktop/odoo-docker-ready/your_project/extra-addons/sr_property_rental_management/reports/reporte_separacion_template.xml -->
<odoo>
    <template id="recibo_pago_template">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <h6 style="text-align: center;background-color: gray;color: white;">RECIBO DE CAJA</h6>
                    <t t-foreach="docs" t-as="doc">
                        <div>
                            <strong class="m-0">Referencia:</strong>
                            <t t-esc="doc.name"/>
                        </div>
                        <div style="page-break-after:always;">
                            <div>
                                <strong class="m-0">Fecha:</strong>
                                <t t-esc="doc.invoice_date"  t-options='{"widget": "date"}'/>
                            </div>
                            <div>
                                <div class='container text-justify'>
                                    <div class="row my-3">
                                        <div style="width:33%" class=" flex-column">
                                            <strong class="m-0">Proyecto:</strong>
                                            <t t-esc="doc.company_id.name"/>
                                        </div>
                                        <div style="width:33%" class=" flex-column">
                                            <strong class="m-0">Cliente:</strong>
                                            <t t-esc="doc.partner_id.name"/>
                                        </div>
                                        <t t-if="doc.tenancy_agreement.co_tenant_id">
                                            <div style="width:33%" class=" flex-column">
                                                <strong class="m-0">Copropietario:</strong>
                                                <t t-esc="doc.tenancy_agreement.co_tenant_id.name"/>
                                            </div>
                                        </t>
                                    </div>
                                    <div class="row my-3">
                                        <div style="width:33%" class=" flex-column">
                                            <strong class="m-0">Habitaciones:</strong>
                                            <t t-esc="doc.property_id.property_badrooms"/>
                                        </div>
                                        <div style="width:33%" class=" flex-column">
                                            <strong class="m-0">Baños:</strong>
                                            <t t-esc="doc.property_id.property_bathrooms"/>
                                        </div>
                                        <div style="width:33%" class=" flex-column">
                                            <strong class="m-0">Parqueos:</strong>
                                            <t t-esc="doc.property_id.property_parking_lots"/>
                                        </div>
                                    </div>
                                    <div class="row my-3">
                                        <div style="width:33%" class=" flex-column">
                                            <strong class="m-0">Apartamento:</strong>
                                            <t t-esc="doc.property_id.name"/>
                                        </div>
                                        <div style="width:33%" class=" flex-column">
                                            <strong class="m-0">Area Construcción:</strong>
                                            <t t-esc="doc.property_id.property_carpet_area"/>
                                        </div>
                                        <div style="width:33%" class=" flex-column">
                                            <strong class="m-0">Precio:</strong>
                                            <t t-out="doc.property_id.property_sale_price" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                        </div>
                                    </div>
                                    <div>
                                 </div>
                                    <t t-if="doc.payment_state != 'invoicing_legacy'">
                                        <t t-set="payments_vals" t-value="doc.sudo()._get_reconciled_info_JSON_values()"/>
                                        <t t-foreach="payments_vals" t-as="payment_vals">
                                            <div class=" flex-column justify-content-between">
                                                <div class="d-flex my-3">
                                                    <div style="width:33%" class=" flex-column">
                                                        <strong class="m-0">Pagado en:</strong>
                                                        <t t-out="payment_vals['date']"  t-options='{"widget": "date"}'/>
                                                    </div>
                                                    <div style="width:33%" class=" flex-column">
                                                        <strong class="m-0">Cuenta:</strong>
                                                        <t t-out="payment_vals['journal_name']"/>
                                                    </div>
                                                </div>
                            <table class="table table-sm o_main_table" name="invoice_line_table">
                                <thead>
                                    <tr>
                                        <th name="th_description" class="text-left">
                                            <span>Description</span>
                                        </th>
                                        <th name="th_quantity" class="text-right">
                                            <span>Quantity</span>
                                        </th>
                                        <th name="th_priceunit" t-attf-class="text-right {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                                            <span>Unit Price</span>
                                        </th>
                                        <th name="th_price_unit" t-if="display_discount" t-attf-class="text-right {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                                            <span>Disc.%</span>
                                        </th>
                                        <th name="th_taxes" t-attf-class="text-left {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                                            <span>Taxes</span>
                                        </th>
                                        <th name="th_subtotal" class="text-right">
                                            <span groups="account.group_show_line_subtotals_tax_excluded">Amount</span>
                                            <span groups="account.group_show_line_subtotals_tax_included">Total Price</span>
                                        </th>
                                    </tr>
                                </thead>
                                <tbody class="invoice_tbody">
                                    <t t-set="current_subtotal" t-value="0"/>
                                    <t t-set="lines" t-value="doc.invoice_line_ids.sorted(key=lambda l: (-l.sequence, l.date, l.move_name, -l.id), reverse=True)"/>
                                    <t t-foreach="lines" t-as="line">
                                        <t t-set="current_subtotal" t-value="current_subtotal + line.price_subtotal" groups="account.group_show_line_subtotals_tax_excluded"/>
                                        <t t-set="current_subtotal" t-value="current_subtotal + line.price_total" groups="account.group_show_line_subtotals_tax_included"/>
                                        <tr t-att-class="'bg-200 font-weight-bold o_line_section' if line.display_type == 'line_section' else 'font-italic o_line_note' if line.display_type == 'line_note' else ''">
                                            <t t-if="not line.display_type" name="account_invoice_line_accountable">
                                                <td name="account_invoice_line_name">
                                                    <span t-field="line.name" t-options="{'widget': 'text'}"/>
                                                </td>
                                                <td class="text-right">
                                                    <span t-field="line.quantity"/>
                                                    <span t-field="line.product_uom_id"  groups="uom.group_uom"/>
                                                </td>
                                                <td t-attf-class="text-right {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                                                    <span class="text-nowrap" t-field="line.price_unit"/>
                                                </td>
                                                <td t-if="display_discount" t-attf-class="text-right {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                                                    <span class="text-nowrap" t-field="line.discount"/>
                                                </td>
                                                <td t-attf-class="text-left {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                                                    <span t-esc="', '.join(map(lambda x: (x.description or x.name), line.tax_ids))" id="line_tax_ids"/>
                                                </td>
                                                <td class="text-right o_price_total">
                                                    <span class="text-nowrap" t-field="line.price_subtotal" groups="account.group_show_line_subtotals_tax_excluded"/>
                                                    <span class="text-nowrap" t-field="line.price_total" groups="account.group_show_line_subtotals_tax_included"/>
                                                </td>
                                            </t>
                                            <t t-if="line.display_type == 'line_section'">
                                                <td colspan="99">
                                                    <span t-field="line.name" t-options="{'widget': 'text'}"/>
                                                </td>
                                                <t t-set="current_section" t-value="line"/>
                                                <t t-set="current_subtotal" t-value="0"/>
                                    </t>
                                            <t t-if="line.display_type == 'line_note'">
                                                <td colspan="99">
                                                    <span t-field="line.name" t-options="{'widget': 'text'}"/>
                                                </td>
                                            </t>
                                        </tr>
                                        <t t-if="current_section and (line_last or lines[line_index+1].display_type == 'line_section')">
                                            <tr class="is-subtotal text-right">
                                                <td colspan="99">
                                                    <strong class="mr16">Subtotal</strong>
                                                    <span
                                                t-esc="current_subtotal"
                                                t-options='{"widget": "monetary", "display_currency": doc.currency_id}'
                                            />
                                                </td>
                                            </tr>
                                        </t>
                                    </t>
                                </tbody>
                            </table>
                                                <div class="d-flex my-3">
                                                    <div style="width:33%" class=" flex-column">
                                                        <strong class="m-0">Monto:</strong>
                                                        <span t-out="payment_vals['amount']"
                                                      t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                                    </div>
                                                    <div style="width:33%" class=" flex-column">
                                                        <strong class="m-0">Tasa:</strong>
                                                        <span t-esc="doc.get_report_data()['conversion_rate']" t-options='{"widget": "float", "precision": 2}'/>
                                                    </div>
                                                </div>
                                            </div>
                                        </t>
                                        <div class="text-center">
                                            <strong>
                                                Realizado por:
                                        </strong>
                                            <div class="pt-5">
                                        __________________________________________________________
                                        </div>
                                            <p>
                                        ESTE RECIBO NO ES VALIDO SI NO ESTA DEBIDAMENTE FIRMADO Y SELLADO POR LA CAJERA GENERAL
                                        </p>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </t>
                </div>
            </t>
        </t>
    </template>
</odoo>