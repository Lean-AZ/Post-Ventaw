<?xml version="1.0" encoding="UTF-8"?>
<odoo>

	<record id="view_move_form_extends_to_add_property_information" model="ir.ui.view">
		<field name="name">view.move.form.extends.to.add.property.information</field>
		<field name="model">account.move</field>
		<field name="inherit_id" ref="account.view_move_form" />
		<field name="arch" type="xml">
			<field name="payment_reference" position="after">
				<field name="is_property_invoice" />
				<field name="computed_mora" invisible="is_property_invoice == False" widget="monetary" options="{'currency_field': 'currency_id'}" optional="show" />
				<field name="mora_pagada_custom_sr" invisible="is_property_invoice == False" widget="monetary" options="{'currency_field': 'currency_id'}" optional="show" />
				<field name="capital_pagado_custom_sr" invisible="is_property_invoice == False" widget="monetary" options="{'currency_field': 'currency_id'}" optional="show" />
				<field name="is_ajuste_de_precio" invisible="is_property_invoice == False" />
				<field name="is_property_addon" invisible="is_property_invoice == False" />
				<field name="property_id" invisible="is_property_invoice == False" required="is_property_invoice == True" />
				<field name="tenancy_agreement" invisible="is_property_invoice == False" required="is_property_invoice == True" />
				<field name="is_property_commission_bill" invisible="1"/>
				<field name="commission_line_line_ids" string="Líneas de comisión vinculadas" invisible="move_type not in ('in_invoice', 'in_refund') or not is_property_invoice" domain="[('allowed_agent_ids', 'in', [partner_id])]" options="{'no_create': True}" placeholder="Vincular líneas de comisión de agente..."/>
				<!-- <field name="commission_line_ids" string="Comisiones vinculadas" invisible="move_type not in ('in_invoice', 'in_refund') or not is_property_invoice" domain="[('allowed_agent_ids', 'in', [partner_id])]" options="{'no_create': True}" placeholder="Vincular líneas de comisión de agente..."/> -->
			</field>
			<xpath expr="//notebook/page[@id='invoice_tab']/field[@name='invoice_line_ids']/tree/field[@name='product_id']" position="before">
				<field name="tenancy_agreement" invisible="1"/>
			</xpath>
			<xpath expr="//notebook/page[@id='aml_tab']/field[@name='line_ids']/tree/field[@name='account_id']" position="before">
				<field name="tenancy_agreement" invisible="1"/>
			</xpath>
		</field>
	</record>

	<record id="view_move_tree_inherit_mora" model="ir.ui.view">
		<field name="name">account.move.tree.inherit.mora</field>
		<field name="model">account.move</field>
		<field name="inherit_id" ref="account.view_out_invoice_tree"/>
		<field name="arch" type="xml">
			<xpath expr="//field[@name='amount_total_in_currency_signed']" position="before">
				<field name="computed_mora" string="Mora Computada" widget="monetary" options="{'currency_field': 'currency_id'}" optional="show" />
				<field name="mora_pagada_custom_sr" string="Mora Pagada" widget="monetary" options="{'currency_field': 'currency_id'}" optional="show" />
				<field name="capital_pagado_custom_sr" string="Capital Pagado" widget="monetary" options="{'currency_field': 'currency_id'}" optional="show" />
			</xpath>
		</field>
	</record>

	<record id="view_account_payment_register_form_inherit_mora" model="ir.ui.view">
		<field name="name">account.payment.register.form.inherit.mora</field>
		<field name="model">account.payment.register</field>
		<field name="inherit_id" ref="account.view_account_payment_register_form"/>
		<field name="arch" type="xml">
			<xpath expr="//field[@name='payment_date']" position="after">
				<field name="is_property_invoice" invisible="1"/>
				<field name="mora_pagada_custom_sr" widget="monetary" options="{'currency_field': 'currency_id'}" invisible="is_property_invoice == False"/>
				<field name="capital_pagado_custom_sr" widget="monetary" options="{'currency_field': 'currency_id'}" invisible="is_property_invoice == False" readonly="1"/>
			</xpath>
		</field>
	</record>

	<record id="view_account_payment_form_inherit_mora" model="ir.ui.view">
		<field name="name">account.payment.form.inherit.mora</field>
		<field name="model">account.payment</field>
		<field name="inherit_id" ref="account.view_account_payment_form"/>
		<field name="arch" type="xml">
			<xpath expr="//field[@name='date']" position="before">
				<field name="is_property_invoice"/>
				<field name="mora_pagada_custom_sr" widget="monetary" options="{'currency_field': 'currency_id'}" invisible="is_property_invoice == False" readonly="state != 'draft'"/>
				<field name="capital_pagado_custom_sr" widget="monetary" options="{'currency_field': 'currency_id'}" invisible="is_property_invoice == False" readonly="state != 'draft'"/>
				<field name="is_reserva"/>
				<field name="monto_en_rd" widget="monetary" options="{'currency_field': 'currency_id'}" invisible="is_property_invoice == False" readonly="state != 'draft'"/>
        <field name="metodo_de_pago" />
        <field name="numero_de_referencia" />
        <field name="banco_emisor" />
        <field name="banco_receptor" />
        <field name="is_property_invoice" readonly="1"/>
        <field name="property_id" widget="many2one_avatar" invisible="is_property_invoice == False" domain="[('is_property', '=', True)]"/>
			</xpath>
		</field>
	</record>

	<record id="view_account_payment_tree_inherit_mora" model="ir.ui.view">
		<field name="name">account.payment.tree.inherit.mora</field>
		<field name="model">account.payment</field>
		<field name="inherit_id" ref="account.view_account_payment_tree"/>
		<field name="arch" type="xml">
			<xpath expr="//field[@name='state']" position="before">
				<field name="is_property_invoice" invisible="1"/>
				<field name="mora_pagada_custom_sr" widget="monetary" options="{'currency_field': 'currency_id'}" optional="show" readonly="1"/>
				<field name="capital_pagado_custom_sr" widget="monetary" options="{'currency_field': 'currency_id'}" optional="show" readonly="1"/>
			</xpath>
		</field>
	</record>

</odoo>