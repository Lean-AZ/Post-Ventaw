<?xml version="1.0" encoding="UTF-8"?>
<odoo>

	<record id="sr_property_project_tree_view"
		model="ir.ui.view">
		<field name="name">sr.property.project.tree.view</field>
		<field name="model">sr.property.project</field>
		<field name="arch" type="xml">
			<tree string="Proyectos" class="o_sale_order">
				<field name="name" readonly="1" decoration-bf="1" />
				<field name="property_id" string="Propiedades" />
				<field name="number_of_units" string="Cantidad de Unidades" />
				<field name="interest_percent" string="Interés Percent" />
				<field name="days_to_compute" string="Días para Computar" />
			</tree>
		</field>
	</record>

	<record id="sr_property_project_form_view"
		model="ir.ui.view">
		<field name="name">sr.property.project.form.view</field>
		<field name="model">sr.property.project</field>
		<field name="arch" type="xml">
			<form string="Proyectos">
				<sheet>
					<div class="oe_title">
						<h1>
							<field name="name" />
						</h1>
					</div>
					<group>
							<field name="number_of_units" readonly="1" />
							<field name="interest_percent" />
							<field name="days_to_compute" />
					</group>
                    <field name="property_id">
                        <tree create="false" edit="false">
                            <field name="name" colspan="4"/>
                            <field name="property_sale_price" colspan="4"/>
                        </tree>
                    </field>
				</sheet>
			</form>
		</field>
	</record>


	<record id="sr_property_project_action"
		model="ir.actions.act_window">
		<field name="name">Proyectos</field>
		<field name="type">ir.actions.act_window</field>
		<field name="res_model">sr.property.project</field>
		<field name="view_mode">tree,form</field>
	</record>

</odoo>