<?xml version="1.0" encoding="UTF-8"?>
<odoo>

	<record id="sr_property_project_tree_view"
		model="ir.ui.view">
		<field name="name">sr.property.project.tree.view</field>
		<field name="model">sr.property.project</field>
		<field name="arch" type="xml">
			<tree string="Proyectos" class="o_sale_order">
				<field name="name" readonly="1" decoration-bf="1" />
				<field name="property_id" string="Propiedades" />
				<field name="number_of_units" string="Cantidad de Unidades" />
				<field name="interest_percent" string="Interés Percent" />
				<field name="days_to_compute" string="Días para Computar" />
                <field name="default_inspector_id" widget="many2one_avatar_user"/>
                <field name="default_technician_id" widget="many2one_avatar_user"/>
			</tree>
		</field>
	</record>

	<record id="sr_property_project_form_view"
		model="ir.ui.view">
		<field name="name">sr.property.project.form.view</field>
		<field name="model">sr.property.project</field>
		<field name="arch" type="xml">
			<form string="Proyectos">
				<sheet>
					<div class="oe_title">
                        <label for="name" string="Nombre del Proyecto"/>
                        <h1>
                            <field name="name" placeholder="Ej: Residencial Las Palmeras"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Información General">
							<field name="number_of_units" readonly="1" />
							<field name="interest_percent" />
							<field name="days_to_compute" />
					</group>
					 <group>
                        <group string="Personal Asignado por Defecto">
                            <field name="code" placeholder="P-001"/>
                            <field name="default_inspector_id" widget="many2one_avatar_user" options="{'no_create': True}"/>
                            <field name="default_technician_id" widget="many2one_avatar_user" options="{'no_create': True}"/>
                        </group>
					</group>
					</group>
                    <group string="Ingenieros del Proyecto">
                        <field name="engineer_ids" context="{'default_project_id': id}">
                            <tree editable="bottom">
                                <field name="name"/>
                            </tree>
                        </field>
                    </group>
                    <field name="property_id">
                        <tree create="false" edit="false">
                            <field name="name" colspan="4"/>
                            <field name="property_sale_price" colspan="4"/>
                        </tree>
                    </field>
				</sheet>
				<div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
			</form>
		</field>
	</record>


	<record id="sr_property_project_action"
		model="ir.actions.act_window">
		<field name="name">Proyectos y Torres</field>
		<field name="type">ir.actions.act_window</field>
		<field name="res_model">sr.property.project</field>
		<field name="view_mode">tree,form</field>
	</record>

	<!-- Categorías de Fallas (helpdesk.ticket.category) -->
	<record id="helpdesk_ticket_category_tree_view" model="ir.ui.view">
		<field name="name">helpdesk.ticket.category.tree</field>
		<field name="model">helpdesk.ticket.category</field>
		<field name="arch" type="xml">
			<tree string="Categorías de Fallas">
				<field name="name"/>
				<field name="active"/>
			</tree>
		</field>
	</record>
	<record id="helpdesk_ticket_category_form_view" model="ir.ui.view">
		<field name="name">helpdesk.ticket.category.form</field>
		<field name="model">helpdesk.ticket.category</field>
		<field name="arch" type="xml">
			<form string="Categoría de Fallas">
				<sheet>
					<group>
						<field name="name"/>
						<field name="active"/>
					</group>
				</sheet>
			</form>
		</field>
	</record>
	<record id="action_helpdesk_ticket_category" model="ir.actions.act_window">
		<field name="name">Categorías de Fallas</field>
		<field name="res_model">helpdesk.ticket.category</field>
		<field name="view_mode">tree,form</field>
	</record>

	<record id="sr_project_engineer_tree_view" model="ir.ui.view">
		<field name="name">sr.project.engineer.tree</field>
		<field name="model">sr.project.engineer</field>
		<field name="arch" type="xml">
			<tree string="Encargados de Proyecto">
				<field name="name"/>
				<field name="project_id"/>
			</tree>
		</field>
	</record>

	<record id="sr_project_engineer_form_view" model="ir.ui.view">
		<field name="name">sr.project.engineer.form</field>
		<field name="model">sr.project.engineer</field>
		<field name="arch" type="xml">
			<form string="Encargado de Proyecto">
				<sheet>
					<group>
						<field name="name"/>
						<field name="project_id"/>
					</group>
				</sheet>
			</form>
		</field>
	</record>

	<record id="action_sr_project_engineer" model="ir.actions.act_window">
		<field name="name">Encargados de Proyecto</field>
		<field name="res_model">sr.project.engineer</field>
		<field name="view_mode">tree,form</field>
	</record>

</odoo>