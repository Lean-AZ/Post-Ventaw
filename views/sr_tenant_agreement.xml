<?xml version="1.0" encoding="UTF-8"?>
<odoo>

	<record id="sr_tenancy_agreement_tree" model="ir.ui.view">
		<field name="name">sr.tenancy.agreement.tree</field>
		<field name="model">sr.tenancy.agreement</field>
		<field name="arch" type="xml">
			<tree string="Tenancy Agreement" class="o_sale_order"
				multi_edit="1" sample="1">
				<field name="name" string="Number" readonly="1"
					decoration-bf="1" />
				<field name="agreement_date" string="Agreement Date"
					widget="date" optional="show" />
				<field name="agreement_start_date" widget="date"
					optional="show" />
				<field name="agreement_expiry_date" widget="date"
					optional="show" />
				<field name="property_id" />
				<field name="state"/>
			</tree>
		</field>
	</record>

	<record id="sr_tenancy_agreement_form" model="ir.ui.view">
		<field name="name">sr.tenancy.agreement.form</field>
		<field name="model">sr.tenancy.agreement</field>
		<field name="arch" type="xml">
			<form string="Tenancy Agreement">
				<header invisible="context.get('hide_header')">
					<!-- <button name="action_confirm" string="Vender Unidad" type="object" class="oe_highlight" state="new" /> -->\
					<field name="linked_commission_line_count" invisible="1" />
					<button name="action_booked" string="Separar Unidad" type="object" class="oe_highlight" state="new" invisible="state != 'new'" />
					<button name="action_create_gatos_legales_invoices" string="Generar Gastos Legales" type="object" class="oe_highlight" invisible="gastos_legales_invoiced != False" />
					<button name="action_create_commission_record" string="Generar Comisión" type="object" class="oe_highlight" invisible="linked_commission_line_count != 0" />


					<button name="action_create_invoice_civiltec" string="Generar Cuotas" type="object" class="oe_highlight" invisible="property_type != 'sale' or state != 'confirm'" />
					<button name="cancel_booked_property" string="Cancelar Reserva" type="object" invisible="property_type != 'sale' or state != 'confirm'" />

					<field name="state" widget="statusbar"
						statusbar_visible="new,running,expired,confirm" />
				</header>
				<sheet>
					<div class="oe_button_box" name="button_box">
					</div>
					<div class="oe_title">
						<h1>
							<field name="name" readonly="1" />
						</h1>
					</div>
					<group>
						<group string="Property And Price Details">
							<field name="company_id"/>
							<field name="property_id" readonly="state != 'new'" options="{'no_create':True, 'no_create_edit':True, 'no_open':True}"/>
							<field name="property_type" />
							<field name="property_rent" widget="monetary"
								options="{'currency_field': 'currency_id', 'field_digits': True}"
								invisible="property_type != 'rent'" />
							<field name="property_sale_price" widget="monetary"
								options="{'currency_field': 'currency_id', 'field_digits': True}"
								invisible="property_type != 'sale'" />
							<field name="reserve_amount" widget="monetary" options="{'currency_field': 'currency_id', 'field_digits': True}" invisible="property_type != 'sale'" readonly="state == 'invoiced'" />
							<field name="initial_amount" widget="monetary" options="{'currency_field': 'currency_id', 'field_digits': True}" invisible="property_type != 'sale'" readonly="state == 'invoiced'" />
							<field name="amount_to_finance" widget="monetary" options="{'currency_field': 'currency_id', 'field_digits': True}" invisible="property_type != 'sale'" readonly="state == 'invoiced'" />
							<field name="financing_amount" widget="monetary" options="{'currency_field': 'currency_id', 'field_digits': True}" invisible="property_type != 'sale'" />
							<field name="formatted_financed_percentage" invisible="property_type != 'sale'" />
							<field name="gastos_legales" widget="monetary" options="{'currency_field': 'currency_id', 'field_digits': True}" invisible="property_type != 'sale'" />
							<field name="gastos_legales_invoiced" readonly="1"/>
						</group>
						<group string="Contract Details">
							<field name="agreement_date" />
							<field name="tenant_id" readonly="state != 'new'" options="{'no_create':True, 'no_create_edit':True, 'no_open':True}"/>
							<field name="co_tenant_id" readonly="state != 'new'" options="{'no_create':True, 'no_create_edit':True, 'no_open':True}"/>
							<field name="co_owner_relationship"/>
							<field name="payment_option" widget="radio"
								invisible="property_type != 'sale'" required="property_type == 'sale'" readonly="state != 'new'" />
							<field name="partial_payment_id"
								invisible="property_type != 'sale' or payment_option != 'installment'" required="property_type == 'sale' and payment_option == 'installment'" readonly="state != 'new'" options="{'no_create': True}" domain="[('property_id', '=', property_id)]" />
							<field name="agreement_start_date"
								invisible="property_type != 'rent'" required="property_type == 'rent'" readonly="state != 'new'" />
							<field name="first_installment_date" invisible="property_type != 'sale' or payment_option != 'installment'" required="property_type == 'sale' and payment_option == 'installment'" readonly="state == 'running'" />
							<label for="agreement_duration" string="Duration"
								invisible="property_type != 'rent'" required="property_type == 'rent'" readonly="state != 'new'" />
							<div invisible="property_type != 'rent'" required="property_type == 'rent'">
								<field name="agreement_duration" class="oe_inline" required="1" readonly="state != 'new'"/>
								<field name="agreement_duration_type" class="oe_inline" required="1" readonly="state != 'new'"/>
							</div>

							<field name="agreement_expiry_date" invisible="property_type != 'rent'" required="property_type == 'rent'" />
							<field name="delivery_date" readonly="state == 'running'" />
						</group>

					</group>
					<group>
						<group string="Agent Commission Details">
							<field name="notario_publico_id" />
							<!-- <field name="agent_id" /> -->
							<field name="agent_type"/>
							<field name="commission_structure_id" />
						</group>
						<group string="Landloard &amp; Maintenance Information">
							<field name="landloard_id" />
							<label for="maintenance_charge" string="Maintenance Charge" />
							<div>
								<field name="maintenance_charge" class="oe_inline"
									required="1" widget="monetary"
									options="{'currency_field': 'currency_id', 'field_digits': True}" />
								<field name="maintenance_interval_type" class="oe_inline"
									required="1" />
							</div>
						</group>
					</group>
					<group>
						<group string="Financial Information">

							<field name="currency_id" invisible="1" />
							<field name="company_id" invisible="1" />
							<field name="total_price" string="Property price" />
							<field name="total_maintenance" string="Maintenance" />
							<field name="commission_price" string="Commission" />
							<field name="final_price" string="Total" />
						</group>
					</group>
				</sheet>
				<div class="oe_chatter">
					<field name="message_follower_ids" />
					<field name="activity_ids" />
					<field name="message_ids" />
				</div>
				<footer invisible="not context.get('hide_header')">
					<button name="action_confirm" string="Confirm Agreement"
						type="object" class="oe_highlight" state="new" />
				</footer>
			</form>
			
		</field>
	</record>


	<record id="sr_property_tenancy_agreement_action"
		model="ir.actions.act_window">
		<field name="name">Tenancy Agreement</field>
		<field name="type">ir.actions.act_window</field>
		<field name="res_model">sr.tenancy.agreement</field>
		<field name="view_mode">tree,form</field>
		<field name="help" type="html">
			<p class="o_view_nocontent_smiling_face">
				Create a New Tenancy Agreements.
			</p>
		</field>
	</record>


	<record id="action_property_tenancy_agreement"
		model="ir.actions.act_window">
		<field name="name">Tenancy Agreement</field>
		<field name="res_model">sr.tenancy.agreement</field>
		<field name="view_mode">tree,form</field>
		<field name="view_id" ref="sr_tenancy_agreement_form" />
		<field name="target">new</field>
	</record>

</odoo>