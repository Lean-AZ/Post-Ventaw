<?xml version="1.0" encoding="UTF-8"?>
<odoo>

	<record id="sr_property_agent_commission_invoiceable_lines_tree_view" model="ir.ui.view">
		<field name="name">sr.property.agent.commission.invoiceable.lines.tree.view</field>
		<field name="model">sr.property.agent.commission.invoiceable.lines</field>
		<field name="arch" type="xml">
			<tree string="Lineas de comisión facturables" class="o_sale_order" create="false" edit="false" sample="1">
				<field name="name" string="Number" readonly="1" decoration-bf="1" />
				<field name="agent_id" />
				<field name="property_id" string="Property" />
				<field name="tenancy_agreement_id" />
				<field name="date" />
				<field name="currency_id" invisible="1"/>
				<field name="amount" />
			</tree>
		</field>
	</record>

	<record id="sr_property_agent_commission_invoiceable_lines_form_view" model="ir.ui.view">
		<field name="name">sr.property.agent.commission.invoiceable.lines.form.view</field>
		<field name="model">sr.property.agent.commission.invoiceable.lines</field>
		<field name="arch" type="xml">
			<form string="Lineas de comisión facturables" create="false" edit="false">
				<sheet>
					<div class="oe_button_box" name="button_box">
					</div>
					<div class="oe_title">
						<h1>
							<field name="name" readonly="1" />
						</h1>
					</div>
					<group>
						<field name="property_id" />
						<field name="tenancy_agreement_id" />
						<field name="date" />
						<field name="agent_id" />
						<field name="currency_id" invisible="1"/>
						<field name="amount" />
						<field name="commission_line_id" />
					</group>
				</sheet>
			</form>
		</field>
	</record>

	<record id="sr_property_agent_commission_invoiceable_lines_action" model="ir.actions.act_window">
		<field name="name">Lineas de comisión facturables</field>
		<field name="type">ir.actions.act_window</field>
		<field name="res_model">sr.property.agent.commission.invoiceable.lines</field>
		<field name="view_mode">tree,form</field>
	</record>

	<record id="sr_property_agent_commission_lines_tree_view" model="ir.ui.view">
		<field name="name">sr.property.agent.commission.lines.tree.view</field>
		<field name="model">sr.property.agent.commission.lines</field>
		<field name="arch" type="xml">
			<tree string="Agent Commission Lines" class="o_sale_order" create="false" edit="false" sample="1">
				<field name="name" string="Number" readonly="1" decoration-bf="1" />
				<field name="property_id" string="Property" />
				<field name="tenancy_agreement_id" />
				<field name="commission_structure_id" />
				<field name="commission_amount" sum="commission_amount"/>
				<field name="paid_amount" sum="paid_amount"/>
				<field name="remaining_amount" sum="remaining_amount"/>
				<field name="commission_percetage" />
				<field name="property_status" />
				<field name="property_client_id" />
				<field name="property_sale_price" />
				<field name="project" />
				<field name="is_commission_settled" invisible="1"/>
				<field name="commission_settlement_id" invisible="1"/>
			</tree>
		</field>
	</record>

	<record id="sr_property_agent_commission_lines_form_view" model="ir.ui.view">
		<field name="name">sr.property.agent.commission.lines.form.view</field>
		<field name="model">sr.property.agent.commission.lines</field>
		<field name="arch" type="xml">
			<form string="Agent Commission Lines" create="false">
				<header>
					<field name="state" widget="statusbar"/>
				</header>
				<sheet>
					<!-- <div class="oe_button_box" name="button_box">
						<button type="object" class="oe_stat_button" icon="fa-pencil-square-o" name="action_view_linked_invoices">
							<field string="Invoices" name="linked_invoice_count" widget="statinfo"/>
						</button>
					</div> -->
					<div class="oe_title">
						<h1>
							<field name="name" readonly="1" />
						</h1>
					</div>
					<group>
						<group>
							<field name="property_id" />
							<field name="tenancy_agreement_id" />
							<field name="date" />
						</group>
						<group>
							<field name="commission_structure_id" />
							<field name="commission_type" widget="radio" invisible="1"/>
							<field name="currency_id" />
							<field name="commission_amount" widget="monetary" options="{'currency_field': 'currency_id', 'field_digits': True}" />
						</group>
						<!-- <group string="Informacion Contable">
							<field name="invoiced_amount" widget="monetary" options="{'currency_field': 'currency_id', 'field_digits': True}" readonly="1"/>
							<field name="paid_amount" widget="monetary" options="{'currency_field': 'currency_id', 'field_digits': True}" readonly="1"/>
							<field name="remaining_amount" widget="monetary" options="{'currency_field': 'currency_id', 'field_digits': True}" readonly="1"/>
						</group> -->
					</group>
					<field name="allowed_agent_ids" invisible="1"/>
					<notebook>
						<page string="Lineas de comisión facturables">
							<field name="invoiceable_line_ids">
								<tree editable="bottom" delete="false">
									<field name="name" />
									<field name="property_id" />
									<field name="tenancy_agreement_id" />
									<field name="date" />
									<field name="agent_id" />
									<field name="currency_id" />
									<field name="amount" />
									<field name="paid_amount" readonly="1"/>
									<field name="remaining_amount" readonly="1"/>
									<field name="state" readonly="1"/>
									<field name="linked_invoice_count" readonly="1"/>
									<button name="action_view_linked_invoices" type="object" string="Ver facturas" icon="fa-file-text-o" class="btn-link" invisible="linked_invoice_count == 0"/>
									<field name="linked_invoices_ids" widget="many2many_tags" options="{'no_create': True}" domain="[('partner_id', '=', agent_id), ('move_type', 'in', ['in_invoice', 'in_refund'])]"/>
								</tree>
							</field>
						</page>
						<!-- <page string="Facturas vinculadas">
							<field name="linked_invoices_ids" nolabel="1" domain="[('partner_id', 'in', allowed_agent_ids), ('move_type', 'in', ['in_invoice', 'in_refund'])]">
								<tree create="false" delete="true">
									<field name="name"/>
									<field name="partner_id"/>
									<field name="invoice_date"/>
									<field name="state"/>
									<field name="amount_total" widget="monetary" options="{'currency_field': 'currency_id'}"/>
									<field name="currency_id" invisible="1"/>
								</tree>
							</field>
						</page> -->
					</notebook>
				</sheet>
			</form>
		</field>
	</record>

	<record id="sr_property_agent_commission_lines_action" model="ir.actions.act_window">
		<field name="name">Agent Commission Lines</field>
		<field name="type">ir.actions.act_window</field>
		<field name="res_model">sr.property.agent.commission.lines</field>
		<field name="view_mode">tree,form</field>
	</record>

	<record id="sr_property_agent_commission_settlement_tree_view" model="ir.ui.view">
		<field name="name">sr.property.agent.commission.settlement.tree.view</field>
		<field name="model">sr.property.agent.commission.settlement</field>
		<field name="arch" type="xml">
			<tree string="Commissions Settlement" class="o_sale_order">
				<field name="name" string="Number" readonly="1" decoration-bf="1" />
				<field name="date" string="Date" />
				<field name="commission_structure_id" />
			</tree>
		</field>
	</record>

	<record id="sr_property_agent_commission_settlement_form_view" model="ir.ui.view">
		<field name="name">sr.property.agent.commission.settlement.form.view</field>
		<field name="model">sr.property.agent.commission.settlement</field>
		<field name="arch" type="xml">
			<form string="Commissions Settlement">
				<header>
					<button name="action_confirm" string="Confirm Settlement" type="object" class="btn-primary" invisible="state not in ['new']" />
					<button name="calculate_agent_commission" string="Calculate Commission" type="object" class="btn-primary" invisible="state not in ['new']" />
					<button name="action_create_invoice" string="Create invoice" type="object" class="btn-primary" invisible="state != 'confirm'"/>
					<field name="state" widget="statusbar" statusbar_visible="new,confirm,invoiced" />
				</header>
				<sheet>
					<div class="oe_button_box" name="button_box">
					</div>
					<div class="oe_title">
						<h1>
							<field name="name" readonly="1" />
						</h1>
					</div>
					<group>
						<group>
							<field name="date" readonly="1"/>
						</group>
						<group>
							<field name="commission_structure_id" readonly="state != 'new'"/>
						</group>
					</group>
					<notebook>
						<page string="Commission Lines">
							<field name="agent_commission_line_ids" readonly="1">
								<tree>
									<field name="commission_line"/>
									<field name="property_id"/>
									<field name="tenancy_agreement_id"/>
									<field name="date"/>
									<field name="commission_amount"/>
								</tree>
							</field>
						</page>
					</notebook>
				</sheet>
			</form>
		</field>
	</record>

	<record id="sr_property_agent_commission_settlement_action" model="ir.actions.act_window">
		<field name="name">Commissions Settlement</field>
		<field name="type">ir.actions.act_window</field>
		<field name="res_model">sr.property.agent.commission.settlement</field>
		<field name="view_mode">tree,form</field>
	</record>

	<record id="sr_agent_commission_structure_action" model="ir.actions.act_window">
		<field name="name">Commission Structure</field>
		<field name="type">ir.actions.act_window</field>
		<field name="res_model">sr.agent.commission.structure</field>
		<field name="view_mode">tree,form</field>
	</record>

	<record id="sr_agent_commission_structure_tree_view" model="ir.ui.view">
		<field name="name">sr.agent.commission.structure.tree.view</field>
		<field name="model">sr.agent.commission.structure</field>
		<field name="arch" type="xml">
			<tree string="Commission Structure" class="o_sale_order">
				<field name="name" string="Name" />
				<field name="percentage" string="Percentage" />
			</tree>
		</field>
	</record>

	<record id="sr_agent_commission_structure_form_view" model="ir.ui.view">
		<field name="name">sr.agent.commission.structure.form.view</field>
		<field name="model">sr.agent.commission.structure</field>
		<field name="arch" type="xml">
			<form string="Commission Structure">
				<sheet>
					<group>
						<field name="name" required="1"/>
						<field name="percentage" required="1"/>
					</group>
					<notebook>
						<page string="Rangos de la Estructura de Comisión">
							<field name="agent_commission_structure_lines_ids">
								<tree string="Rangos de la Estructura de Comisión" editable="bottom">
									<field name="name" required="1"/>
									<field name="percentage" sum="percentage" required="1"/>
									<field name="agent_id" domain="[('is_agent', '=', True)]" required="1"/>
								</tree>
							</field>
						</page>
					</notebook>
				</sheet>
			</form>
		</field>
	</record>
</odoo>
