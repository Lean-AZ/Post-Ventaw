<?xml version="1.0" encoding="UTF-8"?>
<odoo>
	<!-- Inherit CRM Lead Form View to add property_id field -->
	<record id="crm_lead_view_form_inherit_property" model="ir.ui.view">
		<field name="name">crm.lead.form.inherit.property</field>
		<field name="model">crm.lead</field>
		<field name="inherit_id" ref="crm.crm_lead_view_form"/>
		<field name="arch" type="xml">
			<xpath expr="//field[@name='tag_ids']" position="after">
				<field name="property_id" string="Property" 
					   domain="[('is_property','=', True)]" />
			</xpath>
		</field>
	</record>
</odoo>