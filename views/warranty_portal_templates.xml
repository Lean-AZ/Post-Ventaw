<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="menu_warranty_request" model="website.menu">
        <field name="name">Garantias</field>
        <field name="url">/property/warranty/request</field>
        <field name="parent_id" ref="website.main_menu"/>
        <field name="sequence" type="int">45</field>
    </record>

    <template id="warranty_ticket_form" name="Formulario Externo de Garantias">
        <t t-call="website.layout">
            <div class="container my-5">
                <div class="row justify-content-center">
                    <div class="col-lg-8">
                        <h2 class="mb-3">Registro de Ticket de Garantia</h2>
                        <p class="text-muted mb-1">Hola, <strong><t t-esc="partner.name"/></strong>.</p>
                        <p class="text-muted">Completa el formulario para crear tu solicitud de post-venta.</p>

                        <t t-if="error_message">
                            <div class="alert alert-danger" role="alert">
                                <t t-esc="error_message"/>
                            </div>
                        </t>

                        <form action="/warranty/submit" method="post" enctype="multipart/form-data" class="card p-4 shadow-sm">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <input type="hidden" name="token" t-att-value="token"/>

                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">Persona de contacto</label>
                                    <input type="text" name="contact_person_name" class="form-control"
                                           placeholder="Nombre de la persona de contacto"/>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Telefono del contacto</label>
                                    <input type="text" name="contact_phone" class="form-control"
                                           placeholder="Telefono del contacto"/>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Asunto *</label>
                                <input type="text" name="subject" class="form-control" required="required"
                                       placeholder="Ej: Humedad en pared de sala"/>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Unidad *</label>
                                <select id="warranty_unit_id" name="unit_id" class="form-select" required="required">
                                    <option value="">Selecciona tu unidad</option>
                                    <t t-foreach="properties" t-as="property">
                                        <option t-att-value="property.id"
                                                t-att-data-project="property.product_tmpl_id.sr_property_project_id.name or ''">
                                            <t t-esc="property.display_name"/>
                                        </option>
                                    </t>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Proyecto</label>
                                <input type="text" id="warranty_project_name" class="form-control"
                                       placeholder="Se completa al seleccionar la unidad" readonly="readonly"/>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Descripcion *</label>
                                <textarea name="description" class="form-control" rows="4"
                                          required="required"
                                          placeholder="Describe el detalle de la solicitud"></textarea>
                            </div>

                            <div class="row g-3 mb-3">
                                <div class="col-md-6">
                                    <label class="form-label">Dia de preferencia</label>
                                    <select name="preferred_visit_days" class="form-select">
                                        <option value="">Seleccionar o buscar opciones</option>
                                        <option value="lunes">Lunes</option>
                                        <option value="martes">Martes</option>
                                        <option value="miercoles">Miercoles</option>
                                        <option value="jueves">Jueves</option>
                                        <option value="viernes">Viernes</option>
                                        <option value="sabado">Sabado</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Horario de preferencia</label>
                                    <select id="preferred_time_slot" name="preferred_time_slot" class="form-select">
                                        <option value="">Seleccionar o buscar opciones</option>
                                        <option value="am">08:00 AM - 12:00 PM</option>
                                        <option value="pm_early">02:00 PM - 04:00 PM</option>
                                        <option value="pm_late">04:00 PM - 06:00 PM</option>
                                    </select>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Adjuntos (opcional)</label>
                                <input type="file" name="attachments" class="form-control"/>
                            </div>

                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-primary">Reportar Garantia</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
            <script type="text/javascript">
                document.addEventListener('DOMContentLoaded', function () {
                    const unitSelect = document.getElementById('warranty_unit_id');
                    const projectInput = document.getElementById('warranty_project_name');
                    const daySelect = document.querySelector('select[name="preferred_visit_days"]');
                    const slotSelect = document.getElementById('preferred_time_slot');
                    if (!unitSelect || !projectInput) {
                        return;
                    }
                    const syncProject = function () {
                        const selected = unitSelect.options[unitSelect.selectedIndex];
                        projectInput.value = selected ? (selected.getAttribute('data-project') || '') : '';
                    };
                    const validateSaturdaySlot = function () {
                        if (!daySelect || !slotSelect) {
                            return true;
                        }
                        const isSaturday = daySelect.value === 'sabado';
                        const isAfternoon = slotSelect.value === 'pm_early' || slotSelect.value === 'pm_late';
                        if (isSaturday &amp;&amp; isAfternoon) {
                            alert('Atencion: Los sabados solo se permiten visitas en la manana.');
                            slotSelect.value = '';
                            return false;
                        }
                        return true;
                    };
                    unitSelect.addEventListener('change', syncProject);
                    if (daySelect &amp;&amp; slotSelect) {
                        daySelect.addEventListener('change', validateSaturdaySlot);
                        slotSelect.addEventListener('change', validateSaturdaySlot);
                    }
                    syncProject();
                });
            </script>
        </t>
    </template>

    <template id="warranty_token_invalid" name="Token de Garantia Invalido">
        <t t-call="website.layout">
            <div class="container my-5">
                <div class="row justify-content-center">
                    <div class="col-lg-8">
                        <div class="alert alert-danger" role="alert">
                            <h4 class="alert-heading">Enlace no valido</h4>
                            <p class="mb-0">
                                <t t-esc="error_message or 'El token no es valido o ya no esta disponible.'"/>
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <template id="warranty_ticket_success" name="Confirmacion Ticket Garantia">
        <t t-call="website.layout">
            <div class="container my-5">
                <div class="row justify-content-center">
                    <div class="col-lg-8">
                        <div class="alert alert-success" role="alert">
                            Tu ticket fue creado correctamente.
                        </div>
                        <div class="card p-4 shadow-sm">
                            <p class="mb-3">Gracias, <strong><t t-esc="partner.name"/></strong>.</p>
                            <h4 class="mb-3">Resumen de la Solicitud</h4>
                            <p class="mb-1"><strong>Ticket:</strong> <t t-esc="ticket.display_name"/></p>
                            <p class="mb-1"><strong>Radicado:</strong> <t t-esc="ticket.radicado or '-'"/></p>
                            <p class="mb-0"><strong>Unidad:</strong> <t t-esc="ticket.unit_id.display_name"/></p>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>
